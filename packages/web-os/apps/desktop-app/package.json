{
  "name": "@saladtechnologies/web-os-desktop-app",
  "version": "0.1.0",
  "description": "A Salad web application wrapper for the web-based OS emulator",
  "homepage": "https://www.salad.io/",
  "bugs": {
    "url": "https://feedback.salad.io/bugs",
    "email": "support@salad.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SaladTechnologies/salad-applications.git",
    "directory": "packages/web-os/apps/desktop-app"
  },
  "license": "MIT",
  "author": {
    "name": "Salad Chefs",
    "email": "dev@salad.io",
    "url": "https://www.salad.io"
  },
  "main": "src/index.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack",
    "clean": "rimraf dist",
    "watch": "webpack --watch"
  },
  "devDependencies": {
    "@babel/core": "7.12.3",
    "@babel/plugin-transform-runtime": "7.12.1",
    "@babel/preset-env": "7.12.1",
    "@osjs/eslint-config": "1.1.0",
    "@osjs/stylelint-config": "1.0.1",
    "babel-loader": "8.1.0",
    "copy-webpack-plugin": "6.2.1",
    "eslint": "7.11.0",
    "stylelint": "13.7.2",
    "webpack": "5.1.3",
    "webpack-cli": "4.0.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      "@babel/plugin-transform-runtime"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    },
    "extends": "@osjs/eslint-config",
    "parserOptions": {
      "ecmaVersion": 11,
      "sourceType": "module"
    },
    "rules": {
      "linebreak-style": "off",
      "object-curly-spacing": [
        "error",
        "always"
      ],
      "semi": [
        "error",
        "never"
      ]
    }
  },
  "osjs": {
    "type": "package"
  },
  "prettier": {
    "endOfLine": "auto",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "stylelint": {
    "extends": "@osjs/stylelint-config"
  },
  "dependencies": {
    "cross-env": "7.0.2",
    "rimraf": "3.0.2"
  }
}
