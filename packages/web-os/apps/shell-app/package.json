{
  "name": "@saladtechnologies/web-os-shell-app",
  "version": "0.1.0",
  "description": "A web-based OS emulator",
  "homepage": "https://www.salad.io/",
  "bugs": {
    "url": "https://feedback.salad.io/bugs",
    "email": "support@salad.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SaladTechnologies/salad-applications.git",
    "directory": "packages/web-os/apps/shell-app"
  },
  "license": "MIT",
  "author": {
    "name": "Salad Chefs",
    "email": "dev@salad.io",
    "url": "https://www.salad.io"
  },
  "main": "src/client/index.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack",
    "clean": "rimraf dist packages.json",
    "package:discover": "osjs-cli package:discover",
    "watch": "webpack --watch"
  },
  "dependencies": {
    "@osjs/calculator-application": "1.2.8",
    "@osjs/cli": "3.0.25",
    "@osjs/client": "3.1.68",
    "@osjs/dialogs": "3.0.20",
    "@osjs/freedesktop-sounds": "3.0.3",
    "@osjs/gnome-icons": "4.0.5",
    "@osjs/gui": "4.0.34",
    "@osjs/panels": "3.0.28",
    "@osjs/settings-application": "1.1.6",
    "@osjs/standard-dark-theme": "4.0.11",
    "@osjs/standard-theme": "4.0.9",
    "@saladtechnologies/web-os-desktop-app": "workspace:*",
    "@yarnpkg/fslib": "2.3.0",
    "@yarnpkg/libzip": "2.2.1",
    "cross-env": "7.0.2",
    "fontsource-roboto": "3.0.3",
    "hyperapp": "1.2.10",
    "rimraf": "3.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.12.3",
    "@babel/plugin-transform-runtime": "7.12.1",
    "@babel/preset-env": "7.12.1",
    "@osjs/eslint-config": "1.1.0",
    "@osjs/stylelint-config": "1.0.1",
    "babel-loader": "8.1.0",
    "css-loader": "5.0.0",
    "eslint": "7.11.0",
    "html-webpack-plugin": "4.5.0",
    "mini-css-extract-plugin": "1.0.0",
    "node-sass": "4.14.1",
    "optimize-css-assets-webpack-plugin": "5.0.4",
    "sass-loader": "10.0.3",
    "source-map-loader": "1.1.1",
    "stylelint": "13.7.2",
    "webpack": "5.1.3",
    "webpack-cli": "4.0.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      "@babel/plugin-transform-runtime"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    },
    "extends": "@osjs/eslint-config",
    "parserOptions": {
      "ecmaVersion": 11,
      "sourceType": "module"
    },
    "rules": {
      "linebreak-style": "off",
      "object-curly-spacing": [
        "error",
        "always"
      ],
      "semi": [
        "error",
        "never"
      ]
    }
  },
  "prettier": {
    "endOfLine": "auto",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "stylelint": {
    "extends": "@osjs/stylelint-config"
  }
}
